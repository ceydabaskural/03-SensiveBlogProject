
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="single-sidebar-widget newsletter-widget">
    <h4 class="single-sidebar-widget__title">Bülten</h4>
    <div class="form-group mt-30">
        <div class="col-autos">
            <form action="/Newsletter/AddNewsletter/" method="post">
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" name="Email" class="form-control" size="10" >
                    <button id="btn1" class="bbtns d-block mt-2 w-100">Abone Ol</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.getElementById('btn1').addEventListener('click', function() {
        Swal.fire({
            title: 'Abone Olundu!',
            icon: 'success', // success, error, warning, info, question
            confirmButtonText: 'Ok',
            confirmButtonColor: '#3085d6'
        });
    });
</script>
