@model List<Comment>


<div class="comments-area">
    <h4>Yorumlar </h4>
    <div class="comment-list">
        @foreach (var item in Model)
        {
            <div class="single-comment justify-content-between d-flex">
                <div class="user justify-content-between d-flex">
                    <div class="thumb">
                        <img src="@item.AppUser.ImageUrl" style="width:70px" height="50" alt="">
                    </div>
                    <div class="desc">
                        <h5><a href="#">@item.AppUser</a></h5>
                        <p class="date">@item.CreatedDate.ToShortDateString()</p>
                        <p class="comment">
                            @item.Detail
                        </p>
                    </div>
                </div>
            </div>
            <br />
        }
    </div>
</div>

<div class="comment-form">
    <h4>Yorum Yap</h4>
    <form method="post" asp-action="AddComment" asp-controller="Comment">
        <div class="form-group form-inline">
            <div class="form-group col-lg-6 col-md-6 name">
                <input type="text" class="form-control" id="name" placeholder="Adınız" onfocus="this.placeholder = ''" onblur="this.placeholder = 'Enter Name'">
            </div>
            <div class="form-group col-lg-6 col-md-6 email">
                <input type="text" class="form-control" id="surname" placeholder="Soyadınız" onfocus="this.placeholder = ''">
            </div>
        </div>
        <div class="form-group">
            <textarea class="form-control mb-10" rows="5" name="Detail" placeholder="Yorum" onfocus="this.placeholder = ''" onblur="this.placeholder = 'Messege'" required=""></textarea>
        </div>
        <button class="button submit_btn">Gönder</button>
    </form>
</div>

