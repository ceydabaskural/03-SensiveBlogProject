                        </div>
                    
                </div>

                <div class="navigation-area">
                    <div class="row">
                        <div class="col-lg-6 col-md-6 col-12 nav-left flex-row d-flex justify-content-start align-items-center">
                            <div class="thumb">
                                <a href="#"><img class="img-fluid" src="@item.AppUser.ImageUrl" style="width:100px" height="200"></a>
                            </div>
                            <div class="detials">
                                <a href="#"><h4>@item.AppUser.Name @item.AppUser.Surname</h4></a>
                            </div>
                        </div>
                        <div class="col-lg-6 col-md-6 col-12 nav-right flex-row d-flex justify-content-end align-items-center">
                            <div class="detials">
                                    <p><b>@item.AppUser.Description</b></p>
                                </div>
                        </div>
                    </div>
                </div>
