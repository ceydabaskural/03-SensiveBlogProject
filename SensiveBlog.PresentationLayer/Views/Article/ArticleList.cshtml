@model List<Article>
@{
    Layout = null;
    int count = 0;
}

<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container">
    <br /><br />
    <table class="table table-bordered">
        <tr>
            <th>Makale No</th>
            <th>Başlık</th>
            <th>Kategori</th>
            <th>Yazar</th>
            <th>Tarih</th>
            <th>Detaylar</th>
            <th>Sil</th>
            <th>Güncelle</th>
        </tr>
        @foreach (var item in Model)
        {
            count++;
            <tr>
                <td>@count</td>
                <td>@item.Title</td>
                <td>@item.CategoryId</td>
                <td>@item.AppUserId</td>
                <td>@item.CreatedDate.ToString("dd-MMM-yyyy")</td>
                <td><a href="/Article/ArticleDetails/@item.ArticleId" class="btn btn-warning">Detaylar</a></td>
                <td><a href="/Article/DeleteArticle/@item.ArticleId" class="btn btn-danger">Sil</a></td>
                <td><a href="/Article/UpdateArticle/@item.ArticleId" class="btn btn-success">Güncelle</a></td>
            </tr>
        }
    </table>
    <a href="#" class="btn btn-primary">Yeni Makale Girişi</a>
</div>
